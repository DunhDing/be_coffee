generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model account {
  username      String     @unique @db.VarChar(50)
  password_hash String     @db.VarChar(255)
  status        String?    @default("Active") @db.VarChar(20)
  created_at    DateTime   @default(now()) @db.Timestamp(6)
  account_id    String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_id       String?    @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role          role?      @relation(fields: [role_id], references: [role_id], onDelete: NoAction, onUpdate: NoAction)
  customer      customer[]
  employee      employee[]
  token         token[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model branch {
  branch_name      String        @db.VarChar(100)
  address          String?
  phone_number     String?       @db.VarChar(15)
  status           String?       @default("Active") @db.VarChar(20)
  established_date DateTime?     @db.Date
  image            String?       @db.VarChar(255)
  branch_id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_menu      branch_menu[]
  employee         employee[]
  orders           orders[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model branch_menu {
  local_price Decimal  @db.Decimal(10, 2)
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id   String?  @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id  String?  @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch      branch?  @relation(fields: [branch_id], references: [branch_id], onDelete: NoAction, onUpdate: NoAction)
  product     product? @relation(fields: [product_id], references: [product_id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([product_id, branch_id], map: "uk_product_branch")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model customer {
  phone_number  String?         @unique @db.VarChar(15)
  full_name     String          @db.VarChar(100)
  email         String?         @unique @db.VarChar(100)
  total_points  Int?            @default(0)
  customer_id   String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id    String          @db.Uuid
  account       account         @relation(fields: [account_id], references: [account_id], onDelete: NoAction, onUpdate: NoAction)
  orders        orders[]
  point_history point_history[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model employee {
  full_name    String    @db.VarChar(100)
  email        String?   @unique @db.VarChar(100)
  hire_date    DateTime? @db.Date
  phone_number String?   @db.VarChar(15)
  employee_id  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id    String?   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id   String?   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role         String?   @db.VarChar(50)
  gender       Boolean?
  status       Boolean?
  account      account?  @relation(fields: [account_id], references: [account_id], onDelete: NoAction, onUpdate: NoAction)
  branch       branch?   @relation(fields: [branch_id], references: [branch_id], onDelete: NoAction, onUpdate: NoAction)
  orders       orders[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model loyalty_config {
  config_id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  earn_rate_amount   Decimal  @db.Decimal(10, 2)
  earn_rate_point    Int
  redeem_rate_point  Int
  redeem_rate_amount Decimal  @db.Decimal(10, 2)
  created_at         DateTime @default(now()) @db.Timestamp(6)
  updated_at         DateTime @db.Timestamp(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model order_details {
  quantity   Int      @db.SmallInt
  unit_price Decimal  @db.Decimal(10, 2)
  sub_amount Decimal  @db.Decimal(10, 2)
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id   String?  @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id String?  @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orders     orders?  @relation(fields: [order_id], references: [order_id], onDelete: NoAction, onUpdate: NoAction)
  product    product? @relation(fields: [product_id], references: [product_id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([product_id, order_id], map: "uk_product_order")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model orders {
  order_date       DateTime?       @default(now()) @db.Timestamp(6)
  total_amount     Decimal         @default(0) @db.Decimal(10, 2)
  status           String?         @default("Pending") @db.VarChar(20)
  delivery_address String?         @db.VarChar(255)
  points_used      Int?            @default(0)
  points_earned    Int?            @default(0)
  order_id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id      String?         @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employee_id      String?         @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id        String?         @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payment_id       String?         @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_details    order_details[]
  branch           branch?         @relation(fields: [branch_id], references: [branch_id], onDelete: NoAction, onUpdate: NoAction)
  customer         customer?       @relation(fields: [customer_id], references: [customer_id], onDelete: NoAction, onUpdate: NoAction)
  employee         employee?       @relation(fields: [employee_id], references: [employee_id], onDelete: NoAction, onUpdate: NoAction)
  payment_method   payment_method? @relation(fields: [payment_id], references: [payment_id], onDelete: NoAction, onUpdate: NoAction)
  payment          payment[]
  point_history    point_history[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model payment {
  payment_id String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id   String         @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status     payment_status
  orders     orders         @relation(fields: [order_id], references: [order_id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model payment_method {
  method_name String   @unique @db.VarChar(50)
  payment_id  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orders      orders[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model point_history {
  point_change Int
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  history_id   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id  String?   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id     String?   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer     customer? @relation(fields: [customer_id], references: [customer_id], onDelete: NoAction, onUpdate: NoAction)
  orders       orders?   @relation(fields: [order_id], references: [order_id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([customer_id, order_id], map: "uk_customer_order")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model product {
  product_id    String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_name  String          @db.VarChar(100)
  description   String?
  image         String?
  category      String?         @db.VarChar(50)
  is_available  Boolean?        @default(true)
  branch_menu   branch_menu[]
  order_details order_details[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model reward {
  point  Int
  reward String
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model role {
  role_name String    @unique @db.VarChar(50)
  role_id   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account   account[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model token {
  token      String
  expires_at DateTime @db.Timestamp(6)
  token_id   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id String?  @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account    account? @relation(fields: [account_id], references: [account_id], onDelete: NoAction, onUpdate: NoAction)
}

enum payment_status {
  PENDING
  FAILED
  PAID
}
